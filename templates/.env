# Optional: override the default ~/.calmclaw storage directory
# CALMCLAW_DIR=/custom/path/to/calmclaw

# Set to true to ask user confirmation before each command, false to auto-execute
CONFIRM_COMMANDS=false
MAX_TOKEN_INPUT_TO_LLM=4000

CHARS_PER_TOKEN=5

# Derived from MAX_TOKEN_INPUT_TO_LLM via factors (override with absolute value if needed)
# /* MAX_TOKEN_OUTPUT_FACTOR: must match server --max-tokens / MAX_TOKEN_INPUT_TO_LLM
MAX_TOKEN_OUTPUT_FACTOR=0.375
# */
MAX_TOKEN_COMPRESSION_SUMMARY_FACTOR=0.15
SUMMARY_MAX_TOKEN_FACTOR=0.8
SUMMARY_REASONING_EFFORT=medium
MIN_COMPRESS_GROUP_TOKENS=100
GA_CAP_FACTOR=0.5
MAX_TOOL_RESULT_CHARS_FACTOR=0.15
COMPRESSION_PLANNER=ga
MAX_COMMAND_ITERATIONS=100

MLX_SERVER_MODULE=mlx_vlm.server
PORT=8080

# Use mlx_lm.server for text-only models, mlx_vlm.server for vision models
# Text models (DeepSeek, Qwen, Llama, etc.): MLX_SERVER_MODULE=mlx_lm.server
# Vision models (Gemma VLM, etc.): 

MLX_MODEL_PATH=/Users/Shared/.lmstudio/models/lmstudio-community/gpt-oss-safeguard-20b-MLX-MXFP4
ENDPOINT_SUFFIX=v1/chat/completions
MLX_SERVER_MODULE=mlx_lm.server

